{
  "uid": "docintel-infra",
  "title": "DocIntel — Infrastructure",
  "tags": ["docintel", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 100, "title": "QDRANT", "type": "text",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "options": { "content": "## Qdrant — Vector Database", "mode": "markdown" }
    },
    {
      "id": 1, "title": "Qdrant Up", "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"qdrant\"}", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 2, "title": "Collections", "type": "stat",
      "gridPos": { "x": 3, "y": 1, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "qdrant_collections_total", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3, "title": "Total Points (all collections)", "type": "stat",
      "gridPos": { "x": 6, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(qdrant_points_count)", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 4, "title": "REST Request Rate", "type": "stat",
      "gridPos": { "x": 10, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(rest_requests_total{job=\"qdrant\"}[2m]))", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 5, "title": "REST Errors", "type": "stat",
      "gridPos": { "x": 14, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(rest_responses_total{job=\"qdrant\",status=~\"5..\"}[2m]))", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.01 }] } } }
    },
    {
      "id": 6, "title": "Points per Collection", "type": "barchart",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "qdrant_points_count", "legendFormat": "{{collection}}", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7, "title": "Qdrant REST Latency (p99)", "type": "timeseries",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(rest_request_duration_seconds_bucket{job=\"qdrant\"}[5m])) by (le, endpoint))", "legendFormat": "p99 {{endpoint}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    {
      "id": 200, "title": "POSTGRESQL", "type": "text",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 },
      "options": { "content": "## PostgreSQL", "mode": "markdown" }
    },
    {
      "id": 20, "title": "PG Up", "type": "stat",
      "gridPos": { "x": 0, "y": 13, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "pg_up{job=\"postgres\"}", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 21, "title": "Active Connections", "type": "stat",
      "gridPos": { "x": 3, "y": 13, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pg_stat_activity_count{job=\"postgres\",state=\"active\"})", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 }] } } }
    },
    {
      "id": 22, "title": "DB Size", "type": "stat",
      "gridPos": { "x": 6, "y": 13, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "pg_database_size_bytes{datname=\"docintel\"}", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 23, "title": "Cache Hit Ratio", "type": "stat",
      "gridPos": { "x": 10, "y": 13, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "pg_stat_database_blks_hit{datname=\"docintel\"} / clamp_min(pg_stat_database_blks_hit{datname=\"docintel\"} + pg_stat_database_blks_read{datname=\"docintel\"}, 1)", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 0.9 }, { "color": "green", "value": 0.95 }] } } }
    },
    {
      "id": 24, "title": "Deadlocks", "type": "stat",
      "gridPos": { "x": 14, "y": 13, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(pg_stat_database_deadlocks{datname=\"docintel\"}[5m])", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.001 }] } } }
    },
    {
      "id": 25, "title": "Transactions per Second", "type": "timeseries",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(pg_stat_database_xact_commit{datname=\"docintel\"}[2m])", "legendFormat": "commits/s" },
        { "expr": "rate(pg_stat_database_xact_rollback{datname=\"docintel\"}[2m])", "legendFormat": "rollbacks/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 26, "title": "Row Operations per Second", "type": "timeseries",
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(pg_stat_database_tup_inserted{datname=\"docintel\"}[2m])", "legendFormat": "inserts/s" },
        { "expr": "rate(pg_stat_database_tup_updated{datname=\"docintel\"}[2m])", "legendFormat": "updates/s" },
        { "expr": "rate(pg_stat_database_tup_deleted{datname=\"docintel\"}[2m])", "legendFormat": "deletes/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },

    {
      "id": 300, "title": "REDIS", "type": "text",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 1 },
      "options": { "content": "## Redis — Cache & Pub/Sub", "mode": "markdown" }
    },
    {
      "id": 30, "title": "Redis Up", "type": "stat",
      "gridPos": { "x": 0, "y": 25, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_up{job=\"redis\"}", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 31, "title": "Connected Clients", "type": "stat",
      "gridPos": { "x": 3, "y": 25, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_connected_clients{job=\"redis\"}", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 32, "title": "Memory Used", "type": "stat",
      "gridPos": { "x": 6, "y": 25, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_memory_used_bytes{job=\"redis\"}", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 33, "title": "Hit Rate", "type": "stat",
      "gridPos": { "x": 9, "y": 25, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(redis_keyspace_hits_total{job=\"redis\"}[5m]) / clamp_min(rate(redis_keyspace_hits_total{job=\"redis\"}[5m]) + rate(redis_keyspace_misses_total{job=\"redis\"}[5m]), 0.001)", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 0.7 }, { "color": "green", "value": 0.9 }] } } }
    },
    {
      "id": 34, "title": "Ops/s", "type": "stat",
      "gridPos": { "x": 12, "y": 25, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_instantaneous_ops_per_sec{job=\"redis\"}", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 35, "title": "Redis Memory Over Time", "type": "timeseries",
      "gridPos": { "x": 0, "y": 29, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "redis_memory_used_bytes{job=\"redis\"}", "legendFormat": "used" },
        { "expr": "redis_memory_max_bytes{job=\"redis\"}", "legendFormat": "max (limit)" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 36, "title": "Redis Commands per Second", "type": "timeseries",
      "gridPos": { "x": 12, "y": 29, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(redis_commands_total{job=\"redis\"}[2m])", "legendFormat": "{{cmd}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ]
}
