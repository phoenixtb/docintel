{
  "uid": "docintel-spring",
  "title": "DocIntel — Spring Boot Services",
  "tags": ["docintel", "spring", "jvm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jvm_memory_used_bytes, job)",
        "includeAll": false,
        "current": { "text": "api-gateway", "value": "api-gateway" },
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Service Up", "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"$service\"}", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 2, "title": "HTTP Req/s", "type": "stat",
      "gridPos": { "x": 3, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{job=\"$service\"}[2m]))", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 3, "title": "Error Rate (5xx)", "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{job=\"$service\",status=~\"5..\"}[2m]))", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.01 }] } } }
    },
    {
      "id": 4, "title": "JVM Heap Used", "type": "stat",
      "gridPos": { "x": 9, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(jvm_memory_used_bytes{job=\"$service\",area=\"heap\"})", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 5, "title": "JVM Heap Max", "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(jvm_memory_max_bytes{job=\"$service\",area=\"heap\"})", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 6, "title": "Active Threads", "type": "stat",
      "gridPos": { "x": 15, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "jvm_threads_live_threads{job=\"$service\"}", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7, "title": "GC Pause Time", "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(jvm_gc_pause_seconds_sum{job=\"$service\"}[5m]) / rate(jvm_gc_pause_seconds_count{job=\"$service\"}[5m])", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 8, "title": "CPU Usage", "type": "stat",
      "gridPos": { "x": 21, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "process_cpu_usage{job=\"$service\"}", "legendFormat": "" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 10, "title": "HTTP Request Rate by Status", "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"$service\"}[2m]))", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 11, "title": "HTTP Latency — p50 / p95 / p99", "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"$service\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"$service\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"$service\"}[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 12, "title": "JVM Heap Usage Over Time", "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{job=\"$service\",area=\"heap\"})", "legendFormat": "used" },
        { "expr": "sum(jvm_memory_committed_bytes{job=\"$service\",area=\"heap\"})", "legendFormat": "committed" },
        { "expr": "sum(jvm_memory_max_bytes{job=\"$service\",area=\"heap\"})", "legendFormat": "max" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 13, "title": "JVM Thread States", "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "jvm_threads_states_threads{job=\"$service\",state=\"runnable\"}", "legendFormat": "runnable" },
        { "expr": "jvm_threads_states_threads{job=\"$service\",state=\"waiting\"}", "legendFormat": "waiting" },
        { "expr": "jvm_threads_states_threads{job=\"$service\",state=\"timed-waiting\"}", "legendFormat": "timed-waiting" },
        { "expr": "jvm_threads_states_threads{job=\"$service\",state=\"blocked\"}", "legendFormat": "blocked" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 14, "title": "All Services — Up Status", "type": "table",
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=~\"api-gateway|admin-service|document-service\"}", "instant": true, "legendFormat": "{{job}}" }],
      "options": { "sortBy": [{ "displayName": "job" }] },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }], "custom": { "displayMode": "color-background" } } }
    },
    {
      "id": 15, "title": "All Services — Error Rate", "type": "timeseries",
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (job) (rate(http_server_requests_seconds_count{job=~\"api-gateway|admin-service|document-service\",status=~\"5..\"}[2m]))", "legendFormat": "{{job}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
