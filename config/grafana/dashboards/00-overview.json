      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 4, "title": "admin-service", "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"admin-service\"}", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 5, "title": "analytics-service", "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"analytics-service\"}", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 6, "title": "opa", "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"opa\"}", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 7, "title": "qdrant", "type": "stat",
      "gridPos": { "x": 0, "y": 3, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"qdrant\"}", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 8, "title": "postgres", "type": "stat",
      "gridPos": { "x": 4, "y": 3, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"postgres\"}", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 9, "title": "redis", "type": "stat",
      "gridPos": { "x": 8, "y": 3, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"redis\"}", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 10, "title": "RAG Query Rate", "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"rag-service\"}[2m]))", "legendFormat": "req/s" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 11, "title": "RAG Cache Hit Rate", "type": "timeseries",
      "gridPos": { "x": 8, "y": 6, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(rag_cache_hit_total[5m]) / clamp_min(rate(rag_cache_hit_total[5m]) + rate(rag_cache_miss_total[5m]), 0.001)", "legendFormat": "hit rate" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 12, "title": "Overall Error Rate (all services)", "type": "timeseries",
      "gridPos": { "x": 16, "y": 6, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (job) (rate(http_requests_total{status=~\"5..\"}[2m]))", "legendFormat": "{{job}} 5xx" },
        { "expr": "sum by (job) (rate(http_server_requests_seconds_count{status=~\"5..\"}[2m]))", "legendFormat": "{{job}} 5xx (spring)" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 13, "title": "RAG Query Latency p99", "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(rag_query_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 14, "title": "LLM Queue Depth", "type": "timeseries",
      "gridPos": { "x": 8, "y": 13, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rag_llm_queue_waiting", "legendFormat": "waiting requests" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 15, "title": "Qdrant Points (all collections)", "type": "timeseries",
      "gridPos": { "x": 16, "y": 13, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(qdrant_points_count)", "legendFormat": "total vectors" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
