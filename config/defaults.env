# DocIntel — Model + Engine Defaults
# =====================================
# Single source of truth for default model names and engine URLs.
# - Scripts source this file directly.
# - Python tests load it via python-dotenv.
# - docker-compose.yml and rag-service config.py use these values as their defaults.
#
# The active model at runtime is resolved dynamically from PostgreSQL
# (platform_settings → tenants.settings → this fallback).

# ── LLM Engine (controls startup script branching) ────────────────────────────
# lmforge  — LMForge running natively on host (macOS Apple Silicon)  [default]
# ollama   — Ollama running natively on host (any platform)
# vllm     — vLLM running natively or in container (Linux/NVIDIA)
# external — skip local engine checks (any OpenAI-compatible remote API)
LLM_ENGINE=lmforge

# ── Engine URLs ───────────────────────────────────────────────────────────────
# Override in .env to switch engines without code changes.
# LLM_CHAT_URL and LLM_EMBED_URL can point to the same engine or different ones.
#
# LMForge (macOS/Apple Silicon) — default:
#   LLM_CHAT_URL=http://host.docker.internal:11430/v1
#   LLM_EMBED_URL=http://host.docker.internal:11430/v1
# Ollama (any platform):
#   LLM_CHAT_URL=http://host.docker.internal:11434/v1
#   LLM_EMBED_URL=http://host.docker.internal:11434/v1  (requires: ollama pull nomic-embed-text)
# vLLM (Linux/NVIDIA):
#   LLM_CHAT_URL=http://host.docker.internal:8000/v1
#   LLM_EMBED_URL=http://host.docker.internal:8001/v1   (separate embed model instance)
# LM Studio (Windows/macOS):
#   LLM_CHAT_URL=http://host.docker.internal:1234/v1
#   LLM_EMBED_URL=http://host.docker.internal:1234/v1
# Infinity (optional, NVIDIA TensorRT): docker compose --profile infinity up
#   LLM_EMBED_URL=http://infinity:7997/v1
LLM_CHAT_URL=http://host.docker.internal:11430/v1
LLM_EMBED_URL=http://host.docker.internal:11430/v1
LLM_API_KEY=none

# ── Models ────────────────────────────────────────────────────────────────────
# Model naming conventions differ by engine — each engine interprets the model
# field in OpenAI-compatible request bodies in its own way:
#   LMForge → catalog tag format: model:size:quantization  e.g. qwen3.5:4b:4bit
#   Ollama  → tag format:         model:size               e.g. qwen3.5:4b
#   vLLM / LM Studio → HF repo path or model name as loaded
#
# For Ollama: set LLM_ENGINE=ollama, LLM_CHAT_URL to Ollama URL, and update
# LLM_MODEL to Ollama format (e.g. qwen3.5:4b) in .env.
LLM_MODEL=qwen3.5:4b:4bit
LLM_FALLBACK_MODEL=qwen3.5:2b:4bit
LLM_EMBED_MODEL=qwen3-embed:0.6b:8bit

# VLM — multimodal escalation for bitmap-heavy / complex PDF pages (ingestion-service)
LLM_VLM_URL=http://host.docker.internal:11430/v1
LLM_VLM_MODEL=qwen2.5-vl:3b:4bit

# Reranker — LMForge /v1/rerank (replaces Infinity sidecar)
LLM_RERANK_URL=http://host.docker.internal:11430/v1
LLM_RERANK_MODEL=jina-reranker-v2:multilingual

# Expansion model — used only for async conversation summarization, not main queries
LLM_EXPANSION_MODEL=qwen3:1.7b

# ── LLM Generation Sampling Parameters ───────────────────────────────────────
# These are the global env-level fallbacks — the last resort in the resolution chain:
#   tenant DB profile → platform DB profile → built-in code defaults → these values.
#
# Non-thinking mode: low temperature for precise, deterministic RAG answers.
LLM_TEMPERATURE=0.1
LLM_TOP_P=
LLM_MAX_TOKENS=1024
LLM_FREQUENCY_PENALTY=0.3
LLM_PRESENCE_PENALTY=0.0
LLM_REPETITION_PENALTY=1.05
LLM_TOP_K=
LLM_MIN_P=
#
# Thinking mode: Qwen3 official spec — top_p=0.95, top_k=20, min_p=0,
# frequency_penalty=0, presence_penalty=0.3, repetition_penalty=1.1.
# thinking_budget: LMForge two-call hard cap on reasoning tokens (keeps answer room).
# thinking_max_tokens: combined (reasoning + answer) budget → max_tokens in API call.
LLM_THINKING_TEMPERATURE=0.6
LLM_THINKING_TOP_P=0.95
LLM_THINKING_MAX_TOKENS=4096
LLM_THINKING_FREQUENCY_PENALTY=0.0
LLM_THINKING_PRESENCE_PENALTY=0.3
LLM_THINKING_REPETITION_PENALTY=1.2
LLM_THINKING_TOP_K=20
LLM_THINKING_MIN_P=0.0
LLM_THINKING_BUDGET=2048

# Legacy names — used only in the Ollama branch of start.sh / setup.sh
# (keep these in Ollama tag format; they are not sent to LMForge)
DEFAULT_LLM_MODEL=qwen3.5:4b
DEFAULT_FALLBACK_MODEL=phi3:mini
DEFAULT_EMBED_MODEL=qwen3-embed:0.6b

# Reranker — served by LMForge /v1/rerank (see LLM_RERANK_URL / LLM_RERANK_MODEL above)
# Legacy DEFAULT_RERANKER_MODEL kept for Ollama branch of start.sh only
DEFAULT_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Domain classifier — DeBERTa zero-shot (used by ingestion-service + rag-service)
DEFAULT_DOMAIN_CLASSIFIER_MODEL=MoritzLaurer/deberta-v3-base-zeroshot-v1.1-all-33

# Docling document conversion defaults (ingestion-service)
DOCLING_DO_OCR=false
INGESTION_USE_PAGE_ROUTING=true
DOCLING_DO_TABLE_STRUCTURE=true
DOCLING_MAX_WORKERS=2

# Docker platform for images without a native arm64 build (e.g. Infinity).
# On Apple Silicon (arm64): leave as linux/amd64 — Docker Desktop uses Rosetta 2 emulation.
# On Linux amd64 CI/prod: set to linux/amd64 (matches host, no emulation needed).
# Override in .env: DOCKER_DEFAULT_PLATFORM=linux/arm64 if an arm64-native image is available.
DOCKER_DEFAULT_PLATFORM=linux/amd64

