# DocIntel Environment Configuration
# ====================================
# Copy this to .env and customize for your environment

# =============================================================================
# Database
# =============================================================================
POSTGRES_DB=docintel
POSTGRES_USER=docintel
POSTGRES_PASSWORD=docintel_secret

# =============================================================================
# MinIO (S3-compatible storage)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# =============================================================================
# LLM Configuration (via LiteLLM)
# =============================================================================
# Local development (Ollama)
LITELLM_MODEL=ollama/qwen3:4b
LITELLM_FALLBACKS=ollama/phi3:mini,ollama/qwen3:1.7b
EMBEDDING_MODEL=nomic-embed-text
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Production (uncomment and set API keys)
# LITELLM_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# =============================================================================
# Langfuse (Observability)
# =============================================================================
LANGFUSE_PUBLIC_KEY=pk-local
LANGFUSE_SECRET_KEY=sk-local
LANGFUSE_HOST=http://localhost:3000

# Production
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# Security (change in production!)
# =============================================================================
JWT_SECRET=docintel-jwt-secret-change-in-production
NEXTAUTH_SECRET=docintel-langfuse-secret-change-in-prod

# =============================================================================
# Authentik (Identity Provider)
# =============================================================================
# Bootstrap token used by Authentik on first start to create the akadmin API token.
# Must match AUTHENTIK_BOOTSTRAP_TOKEN in docker-compose.yml.
AUTHENTIK_BOOTSTRAP_TOKEN=docintel-api-token-change-in-prod

# Admin service API token — auto-populated by ./scripts/setup-authentik.sh.
# Do not set manually; the script derives it from AUTHENTIK_BOOTSTRAP_TOKEN.
AUTHENTIK_TOKEN=
