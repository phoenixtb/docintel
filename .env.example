# DocIntel Environment Configuration
# ====================================
# Copy this to .env and customize for your environment

# =============================================================================
# Database
# =============================================================================
POSTGRES_DB=docintel
POSTGRES_USER=docintel
POSTGRES_PASSWORD=docintel_secret

# =============================================================================
# MinIO (S3-compatible storage)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# =============================================================================
# LLM Configuration (via LiteLLM)
# =============================================================================
# Local development (Ollama)
LITELLM_MODEL=ollama/qwen3.5:4b
LITELLM_FALLBACKS=ollama/phi3:mini,ollama/qwen3.5:4b
EMBEDDING_MODEL=nomic-embed-text

# Reranker — served by Infinity container (ONNX/TensorRT, GPU/CPU auto-select)
# Model is loaded by Infinity at startup; rag-service calls it over HTTP.
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
INFINITY_URL=http://localhost:7997

# Ingestion service — Docling parse + embed + index pipeline
INGESTION_SERVICE_URL=http://localhost:8001

# Production (uncomment and set API keys)
# LITELLM_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# =============================================================================
# Langfuse (Observability)
# =============================================================================
LANGFUSE_PUBLIC_KEY=pk-local
LANGFUSE_SECRET_KEY=sk-local
LANGFUSE_HOST=http://localhost:3000

# Production
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# Security (MUST change in production!)
# =============================================================================
JWT_SECRET=docintel-jwt-secret-change-in-production
NEXTAUTH_SECRET=docintel-langfuse-secret-change-in-prod

# CORS — comma-separated list of allowed frontend origins
# In production set to your actual frontend URL, e.g. https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3001

# Redis password (used by gateway rate-limiter and session store)
# Change in production: generate with `openssl rand -hex 32`
REDIS_PASSWORD=redissecret

# Grafana admin password (UI at http://localhost:3002)
GRAFANA_PASSWORD=admin

# MinIO / S3 object storage credentials
# In production use IAM roles or a secrets manager (Vault, AWS Secrets Manager)
# MINIO_ROOT_USER=<from secrets manager>
# MINIO_ROOT_PASSWORD=<from secrets manager>

# =============================================================================
# Secrets Rotation Runbook (production)
# =============================================================================
# 1. ZITADEL_MASTERKEY — cannot be changed after first init without data loss.
#    Generate once, store in a secrets manager. Must be exactly 32 characters.
#
# 2. ZITADEL_SERVICE_ACCOUNT_PAT — rotate via Zitadel admin UI → Service Users.
#    Update in secrets manager, restart admin-service.
#
# 3. Database passwords (POSTGRES_PASSWORD / docintel_app_secret)
#    - Update in PostgreSQL: ALTER ROLE docintel_app PASSWORD '...';
#    - Update the secret in your secrets manager
#    - Restart document-service, admin-service, rag-service
#
# 4. Redis password (REDIS_PASSWORD)
#    - Update redis.conf requirepass in your secrets manager
#    - Restart Redis, then api-gateway
#
# 5. MinIO / S3 credentials
#    - Rotate in MinIO admin console or IAM
#    - Update secrets manager entry
#    - Restart document-service
#
# 6. Langfuse keys (LANGFUSE_PUBLIC_KEY / SECRET_KEY)
#    - Rotate in Langfuse → Settings → API Keys
#    - Restart rag-service

# =============================================================================
# Zitadel (Identity Provider — AGPL v3.0, self-hosted, no modification)
# =============================================================================
# Masterkey: must be EXACTLY 32 characters. Cannot be changed after first init.
# Generate: openssl rand -hex 16
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters

# Zitadel admin UI human account (console login at localhost:9090)
# In prod: generate with `openssl rand -base64 24`, store in secrets manager
ZITADEL_ADMIN_USERNAME=zitadel-admin
ZITADEL_ADMIN_PASSWORD=DocIntel@zitadel2024!

# Zitadel DB user password (Zitadel creates and manages the zitadel_app role)
ZITADEL_DB_PASSWORD=zitadel_app_secret

# Auto-populated by ./scripts/setup-zitadel.sh — do not set manually.
ZITADEL_CLIENT_ID=
ZITADEL_PROJECT_ID=
ZITADEL_SERVICE_ACCOUNT_PAT=
