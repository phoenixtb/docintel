# Environment
.env
*.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
dist/
build/
.eggs/

# Kotlin/Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
*.class

# IDE
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store

# DocIntel hardware profile (auto-generated, machine-local)
.docintel-profile
.docintel-profile-shown

# Docker
*.log

# Zitadel bootstrap PAT files (contain secrets — never commit)
config/zitadel/bootstrap/*.pat

# Zitadel System API RSA private key (generated by setup.sh — never commit)
config/zitadel/system-api-private.pem

# Zitadel generated runtime config (written by start.sh after terraform apply)
# The stub file (empty values) IS committed; the populated file is gitignored.
config/zitadel/generated.env
config/zitadel/e2e-sa-key.json

# Zitadel Actions v2 state (written by start.sh for idempotency)
config/zitadel/actions-target-id
config/zitadel/actions-signing-key

# Terraform state and cache (local backend — do not commit)
terraform/stacks/*/terraform.tfstate
terraform/stacks/*/terraform.tfstate.backup
terraform/stacks/*/.terraform/
terraform/stacks/*/.terraform.lock.hcl

# Data (don't commit local data)
data/
*.db
*.sqlite

# Jupyter
.ipynb_checkpoints/

# HuggingFace cache
.cache/

# Test outputs
htmlcov/
.coverage
.pytest_cache/
tests/integration/reports/
tests/integration/.venv/
services/ingestion-service/.venv/

# Local-only docs (scratch space, not committed)
docs/future_features/
docs/intermediate_thoughts/
